  "checklistInfo1Body": "आपातकालीन संपर्क वे लोग हैं जिन्हें Guardian Angela तब संदेश भेजती और कॉल करती है जब आप समय पर चेक-इन नहीं कर पातीं। बिना कम से कम एक संपर्क के, चेन को आगे बढ़ाने की कोई जगह नहीं रहती।",
  "@checklistInfo1Body": {
    "description": "Info sheet body for checklist item 1 (kept under 80 words)."
  },
  "checklistInfo2Body": "सत्र-समाप्ति PIN किसी हमलावर को चुपचाप सक्रिय सत्र बंद करने से रोकती है। वह कोशिश कर सकता है, पर पाँच ग़लत प्रयास चुपचाप आपकी डिस्ट्रेस चेन चालू कर देंगे।",
  "@checklistInfo2Body": {
    "description": "Info sheet body for checklist item 2 (kept under 80 words)."
  },
  "checklistInfo3Body": "स्टेल्थ मोड सक्रिय सत्र को स्क्रीन पर किसी सामान्य चीज़ की तरह छिपाता है — म्यूज़िक प्लेयर, रुका हुआ टाइमर, खाली लॉक स्क्रीन। उपयोग तब करें जब पास का कोई व्यक्ति आपको सुरक्षा ऐप चलाते हुए न देख सके।",
  "@checklistInfo3Body": {
    "description": "Info sheet body for checklist item 3 (kept under 80 words)."
  },
  "checklistInfo4Body": "सिमुलेशन आपके सुरक्षा मोड को पूरा चलाता है, पर असली SMS नहीं भेजता, असली कॉल नहीं लगाता और तेज़ अलार्म नहीं बजाता। ज़रूरत पड़ने से पहले समय-क्रम सीखने के लिए इसका उपयोग करें।",
  "@checklistInfo4Body": {
    "description": "Info sheet body for checklist item 4 (kept under 80 words)."
  },
  "checklistInfo5Body": "कस्टम मोड आपको किसी ख़ास स्थिति के अनुसार चरण, समय और ट्रिगर ट्यून करने देते हैं — घर लौटना, पहली डेट, देर की शिफ़्ट। दो बिल्ट-इन मोड शुरुआती बिंदु हैं, मंज़िल नहीं।",
  "@checklistInfo5Body": {
    "description": "Info sheet body for checklist item 5 (kept under 80 words)."
  },
  "checklistInfo6Body": "नोटिफ़िकेशन अनुमति के बिना Guardian Angela अपनी स्थायी फ़ोरग्राउंड स्थिति नहीं रख सकती, छिपे रिमाइंडर नहीं भेज सकती, और चेन के बढ़ने से पहले आपको सूचित नहीं कर सकती।",
  "@checklistInfo6Body": {
    "description": "Info sheet body for checklist item 6 (kept under 80 words)."
  },
