  "checklistInfo1Body": "Emergency contacts are the people Guardian Angela messages and calls when you fail to check in. Without at least one contact, the chain has nowhere to escalate.",
  "@checklistInfo1Body": {
    "description": "Info sheet body for checklist item 1 (kept under 80 words)."
  },
  "checklistInfo2Body": "A session-end PIN prevents an attacker from quietly ending an active session. They can still attempt it, but typing the wrong PIN five times silently fires your distress chain.",
  "@checklistInfo2Body": {
    "description": "Info sheet body for checklist item 2 (kept under 80 words)."
  },
  "checklistInfo3Body": "Stealth mode disguises the active session as something innocuous on your screen — a music player, a paused timer, a blank lock screen. Use it when somebody nearby cannot see you running a safety app.",
  "@checklistInfo3Body": {
    "description": "Info sheet body for checklist item 3 (kept under 80 words)."
  },
  "checklistInfo4Body": "Simulation runs your safety mode end-to-end without sending real SMS, placing real calls, or sounding the loud alarm. Use it to learn the timings before you ever need them.",
  "@checklistInfo4Body": {
    "description": "Info sheet body for checklist item 4 (kept under 80 words)."
  },
  "checklistInfo5Body": "Custom modes let you tune the steps, timings, and triggers to a specific situation — walking home, a first date, a late shift. The two seed modes are starting points, not the destination.",
  "@checklistInfo5Body": {
    "description": "Info sheet body for checklist item 5 (kept under 80 words)."
  },
  "checklistInfo6Body": "Without notification permission, Guardian Angela cannot keep its persistent foreground status, deliver disguised reminders, or warn you that the chain is about to escalate.",
  "@checklistInfo6Body": {
    "description": "Info sheet body for checklist item 6 (kept under 80 words)."
  },
  "checklistTutorial3Body": "Open the stealth defaults and toggle 'Enable stealth mode'. From there you can pick a fake music brand, hide the session timer, or disguise the home-screen icon.",
  "@checklistTutorial3Body": {
    "description": "Tutorial sheet body for item 3 (kept under 80 words)."
  },
  "checklistTutorial4Body": "Tap the outlined 'Simulate' button on the home screen after selecting a mode. The session runs with an orange border and the [SIM] badge — nothing leaves your phone.",
  "@checklistTutorial4Body": {
    "description": "Tutorial sheet body for item 4 (kept under 80 words)."
  },
  "checklistTutorial5Body": "Open the Modes screen and either edit a seed mode (Walk / Date) or create a new one from scratch. Tweak the chain, add a fake call, set custom timings.",
  "@checklistTutorial5Body": {
    "description": "Tutorial sheet body for item 5 (kept under 80 words)."
  },
