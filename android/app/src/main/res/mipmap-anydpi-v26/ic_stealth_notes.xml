<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon for the 'notes' stealth disguise (StealthAlias_notes).
  Solid app-dark background + the Material 'notes' foreground glyph. Enabled by
  StealthIconChannel.setStealthIcon(notes); exactly one stealth alias (or the
  real Guardian Angela launcher) is enabled at a time. minSdk 26 => adaptive
  XML only, no legacy raster fallback required.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_stealth_background" />
    <foreground android:drawable="@drawable/ic_stealth_fg_notes" />
</adaptive-icon>
