<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ data extraction rules (replaces full-backup-content for cloud
  backup and device transfer). Mirrors backup_rules.xml so Hive DB +
  flutter_secure_storage AES key back up together.
-->
<data-extraction-rules>
  <cloud-backup>
    <include domain="file" path="." />
    <include domain="sharedpref" path="FlutterSecureStorage.xml" />
    <exclude domain="file" path="cache" />
    <exclude domain="database" path="." />
  </cloud-backup>
  <device-transfer>
    <include domain="file" path="." />
    <include domain="sharedpref" path="FlutterSecureStorage.xml" />
    <exclude domain="file" path="cache" />
    <exclude domain="database" path="." />
  </device-transfer>
</data-extraction-rules>
